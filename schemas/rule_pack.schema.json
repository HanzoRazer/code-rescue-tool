{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rule Pack (code_audit)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "signal_logic_version", "pack_hash", "rules"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_by": { "type": "string", "minLength": 1 },
    "signal_logic_version": { "type": "string", "pattern": "^signals_v\\d+$" },
    "pack_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "semantic_hash", "rule_logic_version", "semantic_inputs"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "semantic_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "rule_logic_version": { "type": "integer", "minimum": 1 },
          "semantic_inputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
